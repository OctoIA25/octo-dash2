# =============================================================================
# .dockerignore — reduz contexto enviado pro builder
# =============================================================================

# Node
node_modules
**/node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# Build outputs
dist
dist-ssr
build
*.tsbuildinfo
.vite

# Git
.git
.gitignore
.gitattributes

# IDEs
.vscode
.idea
.cursor
.claude
.kiro
.windsurf
*.swp
*.swo
.DS_Store

# Ambiente local (nunca ir para a imagem — use build args + env vars)
.env
.env.local
.env.*.local
.env.development
.env.test

# Browser profile (NUNCA commitar — contém senhas/cookies)
.chromium-profile
.chrome-profile

# Logs / caches
logs
*.log
coverage
.nyc_output
test-results
tsc.log
console-cleanup-skipped.txt

# Docs grandes (não precisa na imagem)
docs

# Docker files (evitar recursão)
Dockerfile*
docker-compose*.yml
.dockerignore

# Temp
temp
tmp
*.tmp
*.bak
*.cache

# Sistema
Thumbs.db
Desktop.ini
